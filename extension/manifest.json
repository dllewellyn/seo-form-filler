{
    "manifest_version": 3,
    "name": "SEO Autofill Agent",
    "version": "1.0",
    "description": "AI-powered form filler for SEO backlink submission",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "sidePanel"
    ],
    "host_permissions": [
        "http://localhost:8080/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "action": {
        "default_title": "Open SEO Agent"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}